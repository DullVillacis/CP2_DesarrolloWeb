{
  "info": {
    "name": "FoodRescue API",
    "description": "Coleccion de pruebas de la API REST de FoodRescue. Flujo sugerido: 1) Registrar/Login Local y Consumidor (guardan el token solos), 2) Crear oferta (guarda ofertaId), 3) Crear reserva (guarda reservaId), 4) probar el resto.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "tokenLocal",
      "value": ""
    },
    {
      "key": "tokenConsumidor",
      "value": ""
    },
    {
      "key": "ofertaId",
      "value": ""
    },
    {
      "key": "reservaId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar Local",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.collectionVariables.set('tokenLocal', pm.response.json().token);",
                  "  console.log('Guardado tokenLocal:', pm.collectionVariables.get('tokenLocal'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Panadero\",\n  \"email\": \"local@mail.com\",\n  \"password\": \"123456\",\n  \"rol\": \"local\",\n  \"nombreNegocio\": \"Panaderia El Trigo\",\n  \"direccion\": \"Av. Siempre Viva 123\",\n  \"telefono\": \"0999999999\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Registrar Consumidor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.collectionVariables.set('tokenConsumidor', pm.response.json().token);",
                  "  console.log('Guardado tokenConsumidor:', pm.collectionVariables.get('tokenConsumidor'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana Perez\",\n  \"email\": \"ana@mail.com\",\n  \"password\": \"123456\",\n  \"rol\": \"consumidor\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login Local",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.collectionVariables.set('tokenLocal', pm.response.json().token);",
                  "  console.log('Guardado tokenLocal:', pm.collectionVariables.get('tokenLocal'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"local@mail.com\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login Consumidor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.collectionVariables.set('tokenConsumidor', pm.response.json().token);",
                  "  console.log('Guardado tokenConsumidor:', pm.collectionVariables.get('tokenConsumidor'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@mail.com\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Perfil (ruta protegida)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/perfil",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "perfil"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ofertas",
      "item": [
        {
          "name": "Crear oferta (local)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.collectionVariables.set('ofertaId', pm.response.json()._id);",
                  "  console.log('Guardado ofertaId:', pm.collectionVariables.get('ofertaId'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenLocal}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Pack sorpresa de panaderia\",\n  \"descripcion\": \"Pan y pasteles del dia a mitad de precio\",\n  \"categoria\": \"panaderia\",\n  \"precioOriginal\": 10,\n  \"precioDescuento\": 4,\n  \"cantidadDisponible\": 5,\n  \"horarioRetiro\": \"18:00 - 20:00\",\n  \"disponibleHasta\": \"2026-12-31\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/offers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers"
              ]
            }
          }
        },
        {
          "name": "Listar ofertas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/offers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers"
              ]
            }
          }
        },
        {
          "name": "Filtrar ofertas (categoria + precio)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/offers?categoria=panaderia&precioMax=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers"
              ],
              "query": [
                {
                  "key": "categoria",
                  "value": "panaderia"
                },
                {
                  "key": "precioMax",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Mis ofertas (local)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenLocal}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/offers/mias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers",
                "mias"
              ]
            }
          }
        },
        {
          "name": "Ver oferta por id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/offers/{{ofertaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers",
                "{{ofertaId}}"
              ]
            }
          }
        },
        {
          "name": "Editar oferta (local)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenLocal}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"precioDescuento\": 3,\n  \"cantidadDisponible\": 3\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/offers/{{ofertaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers",
                "{{ofertaId}}"
              ]
            }
          }
        },
        {
          "name": "Eliminar oferta (local)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenLocal}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/offers/{{ofertaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "offers",
                "{{ofertaId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reservas",
      "item": [
        {
          "name": "Crear reserva (consumidor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  pm.collectionVariables.set('reservaId', pm.response.json()._id);",
                  "  console.log('Guardado reservaId:', pm.collectionVariables.get('reservaId'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oferta\": \"{{ofertaId}}\",\n  \"cantidad\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/reservations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations"
              ]
            }
          }
        },
        {
          "name": "Mis reservas (consumidor)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations/mias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations",
                "mias"
              ]
            }
          }
        },
        {
          "name": "Reservas de mi local (local)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenLocal}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations/local",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations",
                "local"
              ]
            }
          }
        },
        {
          "name": "Completar reserva (local)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenLocal}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations/{{reservaId}}/completar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations",
                "{{reservaId}}",
                "completar"
              ]
            }
          }
        },
        {
          "name": "Cancelar reserva (consumidor)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tokenConsumidor}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations/{{reservaId}}/cancelar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations",
                "{{reservaId}}",
                "cancelar"
              ]
            }
          }
        }
      ]
    }
  ]
}